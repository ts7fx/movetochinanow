---
interface Props {
  title?: string;
  tone?: 'info' | 'warn' | 'key';
}
const { title, tone = 'info' } = Astro.props;
const glyph = tone === 'warn' ? '!' : tone === 'key' ? '★' : 'i';
---

<aside class:list={['callout', `callout--${tone}`]}>
  <span class="callout-icon" aria-hidden="true">{glyph}</span>
  <div class="callout-main">
    {title && <p class="callout-title">{title}</p>}
    <div class="callout-body"><slot /></div>
  </div>
</aside>

<style>
  .callout {
    display: flex;
    gap: 14px;
    border-radius: var(--radius-md);
    padding: 18px 22px;
    margin: 28px 0;
    border-left: 4px solid var(--color-navy-mid);
    background: var(--color-cream);
  }
  .callout--warn { border-left-color: var(--color-red); background: #fcf3f1; }
  .callout--key { border-left-color: var(--color-navy); background: var(--color-warm-gray); }
  .callout-icon {
    flex: none;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--color-navy-mid);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 0.85rem;
    line-height: 1;
  }
  .callout--warn .callout-icon { background: var(--color-red); }
  .callout--key .callout-icon { background: var(--color-navy); }
  .callout-title {
    font-family: var(--font-serif);
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 6px;
  }
  .callout-body :global(p:last-child) { margin-bottom: 0; }
</style>
