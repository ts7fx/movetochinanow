---
interface Props {
  headers: string[];
  rows: string[][];
  highlightRow?: number;
  caption?: string;
}
const { headers, rows, highlightRow, caption } = Astro.props;
---

<div class="compare-wrap">
  <table class="compare-table">
    {caption && <caption>{caption}</caption>}
    <thead>
      <tr>{headers.map((h) => <th scope="col">{h}</th>)}</tr>
    </thead>
    <tbody>
      {rows.map((row, i) => (
        <tr class:list={[{ 'is-highlight': i === highlightRow }]}>
          {row.map((cell, j) =>
            j === 0 ? <th scope="row" set:html={cell} /> : <td set:html={cell} />
          )}
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .compare-wrap { margin: 28px 0; overflow-x: auto; }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .compare-table caption {
    caption-side: bottom;
    font-size: 0.82rem;
    color: var(--color-text-light);
    padding-top: 10px;
    text-align: left;
  }
  .compare-table th[scope='col'] {
    background: var(--color-navy);
    color: var(--color-white);
    font-family: var(--font-sans);
    font-weight: 600;
    text-align: left;
    padding: 12px 16px;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .compare-table th[scope='row'] {
    text-align: left;
    font-weight: 600;
    color: var(--color-navy);
  }
  .compare-table td,
  .compare-table th[scope='row'] {
    padding: 12px 16px;
    border-top: 1px solid var(--color-border);
    vertical-align: top;
    color: var(--color-text-mid);
  }
  .compare-table tbody tr:nth-child(even) td,
  .compare-table tbody tr:nth-child(even) th[scope='row'] { background: var(--color-cream); }
  .compare-table tr.is-highlight td,
  .compare-table tr.is-highlight th[scope='row'] { background: #fcf3f1; }
  .compare-table tr.is-highlight th[scope='row'] { color: var(--color-red); }
</style>
