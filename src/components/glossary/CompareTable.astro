---
interface Props {
  headers: string[];
  rows: string[][];
  highlightRow?: number;
  caption?: string;
}
const { headers, rows, highlightRow, caption } = Astro.props;
---

<div class="compare-wrap">
  <table class="compare-table">
    {caption && <caption>{caption}</caption>}
    <thead>
      <tr>{headers.map((h) => <th scope="col">{h}</th>)}</tr>
    </thead>
    <tbody>
      {rows.map((row, i) => (
        <tr class:list={[{ 'is-highlight': i === highlightRow }]}>
          {row.map((cell, j) =>
            j === 0 ? <th scope="row" set:html={cell} /> : <td set:html={cell} />
          )}
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .compare-wrap { margin: 30px 0; overflow-x: auto; }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.96rem;
    border-top: 2px solid var(--color-ink);
  }
  .compare-table caption {
    caption-side: bottom;
    font-size: 0.82rem;
    color: var(--color-muted);
    padding-top: 10px;
    text-align: left;
  }
  .compare-table th[scope='col'] {
    background: transparent;
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-weight: 600;
    text-align: left;
    padding: 13px 16px;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 1px solid var(--color-line);
  }
  .compare-table th[scope='row'] {
    text-align: left;
    font-weight: 600;
    color: var(--color-ink);
  }
  .compare-table td,
  .compare-table th[scope='row'] {
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-line-2);
    vertical-align: top;
    color: var(--color-ink-soft);
  }
  .compare-table tr.is-highlight td,
  .compare-table tr.is-highlight th[scope='row'] { background: var(--color-paper-2); }
  .compare-table tr.is-highlight th[scope='row'] { box-shadow: inset 2px 0 0 var(--color-brass); }
</style>
