---
import '../styles/global.css';
import { BUILD_COMMIT, BUILD_BRANCH, BUILD_TIME } from '../lib/build-info';

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  canonical?: string;
  robots?: string;
  ogType?: string;
  ogTitle?: string;
  ogDescription?: string;
  navLinks?: NavLink[];
  footerSections?: NavLink[];
  footerSectionsTitle?: string;
  /**
   * Top-bar tagline (the line under "Free 30-Minute Consultation").
   * Per-page override; defaults to the green-card line. Should end with
   * a "Book now →" anchor — the link to /consultation is added by Layout.
   */
  topbarTagline?: string;
}

const {
  title,
  description,
  canonical,
  robots,
  ogType = 'website',
  ogTitle = title,
  ogDescription = description,
  navLinks,
  footerSections,
  footerSectionsTitle,
  topbarTagline = 'Find out if you qualify for a China green card.',
} = Astro.props;

const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '';
const isConsultation = pathname.startsWith('/consultation');
const canonicalUrl = canonical ?? new URL(pathname, 'https://movetochinanow.com').toString();

const defaultHomeLinks: NavLink[] = [
  { label: 'Eligibility', href: '#who-qualifies' },
  { label: 'Benefits', href: '#benefits' },
  { label: 'How to Apply', href: '#how-to-apply' },
  { label: 'Documents', href: '#documents' },
  { label: 'Timeline & Costs', href: '#timeline' },
  { label: 'FAQ', href: '#faq' },
];

const resolvedNavLinks: NavLink[] | null = navLinks ?? (isHome ? defaultHomeLinks : null);

// Site-level guide directory — every content page registered here so the
// footer can render cross-links automatically.
interface SitePage {
  title: string;
  href: string;
  shortLabel?: string;
}
const sitePages: SitePage[] = [
  { title: 'China Green Card Guide', href: '/', shortLabel: 'Green Card Guide' },
  { title: 'China Residence Permit Guide', href: '/china-residence-permit-guide/', shortLabel: 'Residence Permit Guide' },
  { title: 'PR for Spouse of Chinese Citizen', href: '/china-permanent-residence-for-foreign-spouse-of-chinese-citizen-requirements-2026/', shortLabel: 'Spouse PR Guide' },
  { title: 'China Permanent Residence Permit', href: '/china-permanent-residence-permit/', shortLabel: 'PR Permit' },
  { title: 'China Z Visa & Work Permit', href: '/china-z-visa-work-permit/', shortLabel: 'Z Visa & Work Permit' },
  { title: 'Free Consultation', href: '/consultation/' },
];
const normalizedPath = pathname.endsWith('/') ? pathname : pathname + '/';
const otherPages = sitePages.filter((p) => p.href !== normalizedPath && p.href !== pathname);

const resolvedFooterSections = footerSections ?? resolvedNavLinks ?? defaultHomeLinks;
const footerSectionsHeading = footerSectionsTitle ?? (resolvedNavLinks ? 'On This Page' : 'Guide');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Seres Immigration" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />

    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='12' fill='%23c0392b'/><text y='.9em' x='50' text-anchor='middle' font-size='70' fill='white'>S</text></svg>" />

    <meta name="build-commit" content={BUILD_COMMIT} />
    <meta name="build-branch" content={BUILD_BRANCH} />
    <meta name="build-time" content={BUILD_TIME} />

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-KEJMX89R6L"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-KEJMX89R6L');
    </script>

    <slot name="head" />
  </head>
  <body>
    <div class="topbar">
      <div class="container">
        <strong>Free 30-Minute Consultation</strong> — {topbarTagline} <a href="/consultation">Book now &rarr;</a>
      </div>
    </div>

    <nav class="nav" role="navigation" aria-label="Main navigation">
      <div class="container">
        <div class="nav-inner">
          <a href="/" class="nav-logo">
            <div class="nav-logo-mark" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><path d="M3 12l9-9 9 9M5 10v10a1 1 0 001 1h3m10-11v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001 1h4a1 1 0 001-1v-5a1 1 0 00-1-1h-4a1 1 0 00-1 1v5z"/></svg>
            </div>
            <div>
              <div class="nav-logo-text">Seres Immigration</div>
              <div class="nav-logo-sub">Live More for Less</div>
            </div>
          </a>
          {resolvedNavLinks && (
            <ul class="nav-links">
              {resolvedNavLinks.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          )}
          <div class="nav-cta">
            {isConsultation ? (
              <a href="/" class="btn btn-primary" style="padding:10px 20px; font-size:.85rem;">Back to Guide</a>
            ) : (
              <a href="/consultation" class="btn btn-primary" style="padding:10px 20px; font-size:.85rem;">Free Consultation</a>
            )}
            <button class="nav-mobile-btn" aria-label="Toggle menu" aria-expanded="false" data-nav-toggle>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <slot />

    <footer>
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <a href="/" class="footer-logo">
              <div class="footer-logo-mark" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><path d="M3 12l9-9 9 9M5 10v10a1 1 0 001 1h3m10-11v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001 1h4a1 1 0 001-1v-5a1 1 0 00-1-1h-4a1 1 0 00-1 1v5z"/></svg>
              </div>
              <span class="footer-logo-text">Seres Immigration</span>
            </a>
            <p class="footer-desc">The only immigration consultancy focused exclusively on helping Westerners relocate to China. Based in Shenzhen, Shanghai, Fuzhou &amp; California.</p>
            <p style="color: rgba(255,255,255,.5); font-size: .85rem;">
              <a href="mailto:info@seresimmigration.com" style="color: rgba(255,255,255,.75);">info@seresimmigration.com</a>
            </p>
          </div>
          <div class="footer-col">
            <h5>{footerSectionsHeading}</h5>
            <ul>
              {resolvedFooterSections.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
          {otherPages.length > 0 && (
            <div class="footer-col">
              <h5>Other Guides</h5>
              <ul>
                {otherPages.map((page) => (
                  <li><a href={page.href}>{page.shortLabel ?? page.title}</a></li>
                ))}
              </ul>
            </div>
          )}
          <div class="footer-col">
            <h5>Company</h5>
            <ul>
              <li><a href="/">Seres Immigration</a></li>
              <li><a href="/consultation">Free Consultation</a></li>
              <li><a href="mailto:info@seresimmigration.com">Contact Us</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <span>&copy; 2026 Seres Immigration. All rights reserved.</span>
          <div style="display:flex; gap:16px;">
            <a href="/consultation">Book Consultation</a>
            <a href="mailto:info@seresimmigration.com">Contact</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const navEl = document.querySelector<HTMLElement>('.nav');
      const toggleBtn = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
      toggleBtn?.addEventListener('click', () => {
        const open = navEl?.hasAttribute('data-nav-open');
        if (open) {
          navEl?.removeAttribute('data-nav-open');
          toggleBtn.setAttribute('aria-expanded', 'false');
        } else {
          navEl?.setAttribute('data-nav-open', '');
          toggleBtn.setAttribute('aria-expanded', 'true');
        }
      });
    </script>
  </body>
</html>
