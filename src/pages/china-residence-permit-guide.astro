      padding: 9px 0; border-bottom: 1px solid var(--rp-clr-border);
      font-size: 0.91rem; color: var(--rp-clr-ink-mid);
    }
    .rp-checklist li:last-child { border-bottom: none; }
    .rp-check { flex-shrink: 0; color: var(--rp-clr-ok-brd); margin-top: 3px; }

    /* registration cards */
    .rp-reg-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 24px 0; }
    .rp-reg-card {
      border-radius: var(--rp-radius); padding: 20px 22px;
      border: 1px solid var(--rp-clr-border); background: var(--rp-clr-surface);
    }
    .rp-reg-card__header { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
    .rp-reg-card__icon {
      width: 40px; height: 40px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .rp-reg-card__icon--hotel { background: #EEF4FF; }
    .rp-reg-card__icon--private { background: #FEF3E2; }
    .rp-reg-card h4 { font-size: 0.95rem; color: var(--rp-clr-ink); margin-bottom: 0; }
    .rp-reg-card p { font-size: 0.86rem; margin-bottom: 0; }

    /* path flow */
    .rp-path-flow { display: flex; flex-direction: column; gap: 0; margin: 24px 0; }
    .rp-path-node { display: flex; align-items: stretch; gap: 16px; }
    .rp-path-node__line-wrap {
      display: flex; flex-direction: column; align-items: center;
      flex-shrink: 0; width: 32px;
    }
    .rp-path-node__dot {
      width: 14px; height: 14px; border-radius: 50%;
      background: var(--rp-clr-primary); flex-shrink: 0; margin-top: 4px; z-index: 1;
    }
    .rp-path-node__dot--end { background: var(--rp-clr-ok-brd); }
    .rp-path-node__connector { flex: 1; width: 2px; background: var(--rp-clr-border); margin: 2px 0; }
    .rp-path-node__content {
      background: var(--rp-clr-surface); border: 1px solid var(--rp-clr-border);
      border-radius: var(--rp-radius); padding: 14px 16px; margin-bottom: 8px; flex: 1;
    }
    .rp-path-node__content h4 { margin: 3px 0; font-size: 0.92rem; }
    .rp-path-node__content p { font-size: 0.84rem; margin-bottom: 0; }
    .rp-path-node__pill {
      display: inline-block; font-size: 0.7rem; font-weight: 700;
      background: var(--rp-clr-tag-bg); color: var(--rp-clr-tag-txt);
      padding: 1px 8px; border-radius: 20px; margin-bottom: 5px;
    }
    .rp-path-node__pill--goal { background: #EAF5EA; color: #256625; }

    /* FAQ */
    .rp-faq { margin: 24px 0; }
    .rp-faq__item {
      background: var(--rp-clr-surface);
      border: 1px solid var(--rp-clr-border);
      border-radius: var(--rp-radius);
      margin-bottom: 10px;
      padding: 16px 20px;
    }
    .rp-faq__item summary {
      font-weight: 700; color: var(--rp-clr-ink);
      cursor: pointer; font-size: 0.95rem;
    }
    .rp-faq__item[open] summary { margin-bottom: 10px; }
    .rp-faq__item p { margin-bottom: 0; font-size: 0.92rem; }

    /* CTA block — dark to match hero */
    .rp-cta-block {
      background: #1A1A1A; border-radius: var(--rp-radius-lg);
      padding: 48px 36px; text-align: center; margin: 52px 0 0;
    }
    .rp-cta-block h2 { color: #fff; margin-bottom: 10px; }
    .rp-cta-block p { color: #C8C4BC; margin-bottom: 24px; max-width: 500px; margin-left: auto; margin-right: auto; }

    /* Restore hero/CTA text colors. Astro's CSS scoping appends
       [data-astro-cid-*] to .rp-guide selectors, which boosts their
       specificity above plain .hero h1 / .hero-sub / .btn-primary in
       global.css. Re-assert the dark-bg colors here, where the page's
       own scoping works in our favor. */
    .rp-guide .hero h1 { color: #fff; }
    .rp-guide .hero .hero-sub { color: rgba(255, 255, 255, 0.75); }
    .rp-guide .hero .btn-primary,
    .rp-guide .rp-cta-block .btn-primary { color: #fff; }
    .rp-guide .hero .btn-primary:hover,
    .rp-guide .rp-cta-block .btn-primary:hover { color: #fff; }
    .rp-guide .hero .btn-outline { color: #fff; }
    .rp-cta-trust {
      display: flex; flex-wrap: wrap; justify-content: center;
      gap: 20px; margin-top: 22px;
    }
    .rp-cta-trust__item {
      display: flex; align-items: center; gap: 7px;
      font-size: 0.8rem; color: #9E9994;
    }

    /* responsive */
    @media (max-width: 700px) {
      .rp-hero { padding: 44px 18px 38px; }
      .rp-cta-block { padding: 28px 18px; }
      .rp-toc-wrap { padding: 18px 16px; }
    }
    @media (max-width: 600px) {
      .rp-compare-grid { grid-template-columns: 1fr; }
      .rp-penalty-grid { grid-template-columns: 1fr; }
      .rp-reg-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .rp-hero__ctas { flex-direction: column; }
      .rp-btn-primary, .rp-btn-ghost { text-align: center; }
    }
  </style>
</Layout>
