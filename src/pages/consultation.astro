                  </div>
                </div>
              </div>

              <div class="form-row form-row--single">
                <div class="form-field">
                  <label class="form-label" for="situation">Tell us about your situation</label>
                  <textarea class="form-textarea" id="situation" name="situation" rows="5" placeholder="Years in China, marital status, current work, income level, and anything else that matters — the more context, the better we can help."></textarea>
                  <div class="form-helper">Optional, but highly recommended. Everything shared here is confidential.</div>
                </div>
              </div>
            </div>

            <!-- Section 3: How to Reach You -->
