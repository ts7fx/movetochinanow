---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Book Your Free Consultation — Seres Immigration"
  description="Book a free 30-minute consultation with a Seres Immigration consultant. We review your situation and identify the strongest China green card pathway for you."
  canonical="https://movetochinanow.com/consultation"
  robots="noindex, follow"
  ogType="website"
  ogDescription="A 30-minute eligibility review, tailored to your specific situation."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-badge">
          <span class="hero-badge-dot" aria-hidden="true"></span>
          Free 30-Minute Consultation
        </div>
        <h1 class="text-balance">Tell Us About Your Situation</h1>
        <p class="hero-sub">We read every submission personally. One of our consultants will reply within 24 hours with an honest assessment of your eligibility and the strongest pathway forward.</p>
      </div>
    </div>
  </section>

  <!-- Form Section -->
  <section class="form-wrap">
    <div class="container">
      <div class="form-layout">

        <!-- Form Card -->
        <div class="form-card">
          <div class="form-intro">
            <h2>Consultation Request</h2>
            <p>The more accurately you describe your situation, the more useful your first call will be. Fields marked <span style="color: var(--color-red); font-weight:600;">*</span> are required.</p>
          </div>

          <form action="https://formspree.io/f/maqababr" method="POST" novalidate>
            <input type="hidden" name="_subject" value="New consultation request — movetochinanow.com" />
            <input type="hidden" name="_next" value="https://movetochinanow.com/thank-you" />
            <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

            <!-- Section 1: About You -->
            <div class="form-section">
              <div class="form-section-title">
                <span class="form-section-num">01</span>
                <h3>About You</h3>
              </div>

              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="name">Full Name <span class="form-req">*</span></label>
                  <input class="form-input" type="text" id="name" name="name" required autocomplete="name" />
                </div>
                <div class="form-field">
                  <label class="form-label" for="email">Email Address <span class="form-req">*</span></label>
                  <input class="form-input" type="email" id="email" name="email" required autocomplete="email" />
                </div>
              </div>

              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="nationality">Nationality <span class="form-req">*</span></label>
                  <input class="form-input" type="text" id="nationality" name="nationality" required placeholder="e.g. American, British, Australian" />
                  <div class="form-helper">Affects which background check document you'll need (FBI, ACRO, etc.).</div>
                </div>
                <div class="form-field">
                  <label class="form-label" for="location">Where are you now? <span class="form-req">*</span></label>
                  <select class="form-select" id="location" name="location" required>
                    <option value="">Select an option</option>
                    <option value="in_china">Currently in China</option>
                    <option value="outside_china">Outside China</option>
                    <option value="moving_soon">Outside, moving within 12 months</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Section 2: Your Situation -->
            <div class="form-section">
              <div class="form-section-title">
                <span class="form-section-num">02</span>
                <h3>Your Situation</h3>
              </div>

              <div class="form-row form-row--single">
                <div class="form-field">
                  <label class="form-label">Which pathway are you exploring? <span class="form-req">*</span></label>
                  <div class="choice-grid" role="radiogroup" aria-label="Pathway">
                    <label class="choice-item"><input type="radio" name="pathway" value="professional" required /> Professional</label>
                    <label class="choice-item"><input type="radio" name="pathway" value="spouse" /> Spouse / Family</label>
                    <label class="choice-item"><input type="radio" name="pathway" value="talent" /> Talent</label>
                    <label class="choice-item"><input type="radio" name="pathway" value="investor" /> Investor</label>
                    <label class="choice-item"><input type="radio" name="pathway" value="unsure" /> Not sure yet</label>
                  </div>
                </div>
              </div>

              <div class="form-row form-row--single">
                <div class="form-field">
                  <label class="form-label">Your expected timeline <span class="form-req">*</span></label>
                  <div class="choice-grid" role="radiogroup" aria-label="Timeline">
                    <label class="choice-item"><input type="radio" name="timeline" value="now" required /> Ready to apply now</label>
                    <label class="choice-item"><input type="radio" name="timeline" value="6mo" /> Within 6 months</label>
                    <label class="choice-item"><input type="radio" name="timeline" value="12mo" /> 6–12 months out</label>
                    <label class="choice-item"><input type="radio" name="timeline" value="exploring" /> Just exploring</label>
                  </div>
                </div>
              </div>

              <div class="form-row form-row--single">
                <div class="form-field">
                  <label class="form-label" for="situation">Tell us about your situation</label>
                  <textarea class="form-textarea" id="situation" name="situation" rows="5" placeholder="Years in China, marital status, current work, income level, and anything else that matters — the more context, the better we can help."></textarea>
                  <div class="form-helper">Optional, but highly recommended. Everything shared here is confidential.</div>
                </div>
              </div>
            </div>

            <!-- Section 3: How to Reach You -->
            <div class="form-section">
              <div class="form-section-title">
                <span class="form-section-num">03</span>
                <h3>How to Reach You</h3>
              </div>

              <div class="form-row form-row--single">
                <div class="form-field">
                  <label class="form-label">Preferred contact method <span class="form-req">*</span></label>
                  <div class="choice-grid" role="radiogroup" aria-label="Preferred contact method">
                    <label class="choice-item"><input type="radio" name="contact_method" value="email" required /> Email</label>
                    <label class="choice-item"><input type="radio" name="contact_method" value="whatsapp" /> WhatsApp</label>
                    <label class="choice-item"><input type="radio" name="contact_method" value="wechat" /> WeChat</label>
                    <label class="choice-item"><input type="radio" name="contact_method" value="phone" /> Phone</label>
                  </div>
                </div>
              </div>

              <div class="form-row form-row--single">
                <div class="form-field">
                  <label class="form-label" for="contact_handle">Phone / WhatsApp / WeChat ID</label>
                  <input class="form-input" type="text" id="contact_handle" name="contact_handle" placeholder="Include country code if phone / WhatsApp" autocomplete="tel" />
                  <div class="form-helper">Only needed if you selected WhatsApp, WeChat, or Phone above.</div>
                </div>
              </div>
            </div>

            <div class="form-submit">
              <button type="submit" class="btn btn-primary btn-lg btn-block">Send My Request</button>
              <p class="form-submit-note">
                By submitting, you consent to us contacting you about your consultation. We never share your details or use them for marketing.
              </p>
            </div>

          </form>
        </div>

        <!-- Trust Sidebar -->
        <aside class="trust-panel" aria-label="What happens next">
          <h3>What Happens Next</h3>
          <ul class="trust-list">
            <li class="trust-item">
              <div class="trust-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="#0f1f3d" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h10v10H3z"/><path d="M6 7l2 2 4-4"/></svg>
              </div>
              <div class="trust-text">
                <h4>1. We review your submission</h4>
                <p>A consultant personally reads every request — not a form bot.</p>
              </div>
            </li>
            <li class="trust-item">
              <div class="trust-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="#0f1f3d" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="6.5"/><path d="M8 4.5V8l2.5 1.5"/></svg>
              </div>
              <div class="trust-text">
                <h4>2. Reply within 24 hours</h4>
                <p>You'll receive a written initial assessment by email.</p>
              </div>
            </li>
            <li class="trust-item">
              <div class="trust-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="#0f1f3d" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h12v8H5l-3 3z"/></svg>
              </div>
              <div class="trust-text">
                <h4>3. Free 30-minute call</h4>
                <p>If you want to go deeper, we book a call at your preferred time.</p>
              </div>
            </li>
          </ul>

          <hr class="trust-divider" />

          <h3>Your Privacy</h3>
          <ul class="trust-list">
            <li class="trust-item">
              <div class="trust-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="#0f1f3d" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2l5 2v4c0 3-2.5 5.5-5 6-2.5-.5-5-3-5-6V4l5-2z"/></svg>
              </div>
              <div class="trust-text">
                <h4>Confidential by default</h4>
                <p>Your information stays between you and our team. No sharing, no mailing lists, no marketing.</p>
              </div>
            </li>
          </ul>

          <hr class="trust-divider" />

          <div class="trust-alt">
            <h3>Prefer Email?</h3>
            <p>Skip the form and write to us directly.</p>
            <a class="email-link" href="mailto:info@seresimmigration.com?subject=China%20Green%20Card%20Consultation">
              info@seresimmigration.com
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M3 3h6v6"/><path d="M3 9l6-6"/></svg>
            </a>
          </div>
        </aside>

      </div>
    </div>
  </section>
</Layout>

<style is:global>
  /* Hero (consultation-specific: compact) */
  .hero {
    background: var(--color-navy); position: relative; overflow: hidden; padding: 64px 0 56px;
    color: var(--color-white);
  }
  .hero::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(192,57,43,.18) 0%, transparent 60%),
                url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.025'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }
  .hero-inner { position: relative; z-index: 1; max-width: 780px; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(192,57,43,.22); border: 1px solid rgba(192,57,43,.4);
    border-radius: 100px; color: #f5b7b1; font-size: .8rem; font-weight: 600;
    letter-spacing: .06em; text-transform: uppercase; padding: 5px 14px; margin-bottom: 22px;
  }
  .hero-badge-dot { width: 7px; height: 7px; background: var(--color-red-light); border-radius: 50%; }
  .hero h1 { color: var(--color-white); margin-bottom: 14px; font-size: clamp(2rem, 5vw, 2.8rem); }
  .hero-sub { font-size: 1.1rem; color: rgba(255,255,255,.78); line-height: 1.6; }

  /* Form Layout */
  .form-wrap { padding: 60px 0 80px; background: var(--color-cream); }
  .form-layout {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    gap: 40px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .form-layout { grid-template-columns: 1fr; gap: 28px; }
  }

  .form-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 44px 44px;
    box-shadow: var(--shadow-md);
  }
  @media (max-width: 640px) {
    .form-card { padding: 28px 22px; }
  }

  .form-intro { margin-bottom: 32px; padding-bottom: 28px; border-bottom: 1px solid var(--color-border); }
  .form-intro h2 { margin-bottom: 8px; font-size: clamp(1.5rem, 3vw, 2rem); }
  .form-intro p { color: var(--color-text-light); font-size: .95rem; }

  .form-section { padding-top: 28px; margin-top: 28px; border-top: 1px solid var(--color-border); }
  .form-section:first-of-type { padding-top: 0; margin-top: 0; border-top: none; }
  .form-section-title {
    display: flex; align-items: baseline; gap: 10px; margin-bottom: 20px;
  }
  .form-section-num {
    font-family: var(--font-serif); font-weight: 700; font-size: .95rem;
    color: var(--color-red); letter-spacing: .04em;
  }
  .form-section-title h3 { margin: 0; font-size: 1.25rem; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 18px; }
  .form-row--single { grid-template-columns: 1fr; }
  @media (max-width: 560px) { .form-row { grid-template-columns: 1fr; } }

  .form-field { display: flex; flex-direction: column; }
  .form-label {
    font-size: .85rem; font-weight: 600; color: var(--color-navy);
    margin-bottom: 7px; letter-spacing: .01em;
  }
  .form-req { color: var(--color-red); margin-left: 2px; }
  .form-input, .form-select, .form-textarea {
    width: 100%; font-family: var(--font-sans); font-size: .98rem;
    padding: 12px 14px; border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm); background: var(--color-white);
    color: var(--color-text); transition: border-color .15s, box-shadow .15s;
  }
  .form-input:focus, .form-select:focus, .form-textarea:focus {
    outline: none; border-color: var(--color-red);
    box-shadow: 0 0 0 3px rgba(192,57,43,.12);
  }
  .form-textarea { resize: vertical; min-height: 110px; line-height: 1.6; }
  .form-select {
    appearance: none; -webkit-appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%236b6b70' stroke-width='1.6' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat; background-position: right 14px center;
    padding-right: 38px;
  }
  .form-helper { font-size: .8rem; color: var(--color-text-light); margin-top: 6px; line-height: 1.5; }

  /* Choice cards */
  .choice-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 10px;
  }
  .choice-item {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 14px; border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md); background: var(--color-white);
    cursor: pointer; transition: border-color .15s, background .15s;
    font-size: .92rem; color: var(--color-text-mid); font-weight: 500;
  }
  .choice-item:hover { border-color: var(--color-text-light); }
  .choice-item input {
    appearance: none; -webkit-appearance: none;
    width: 16px; height: 16px; border: 1.5px solid var(--color-border);
    border-radius: 50%; margin: 0; flex-shrink: 0; position: relative;
    transition: border-color .15s;
  }
  .choice-item input:checked { border-color: var(--color-red); }
  .choice-item input:checked::after {
    content: ''; position: absolute; inset: 3px;
    background: var(--color-red); border-radius: 50%;
  }
  .choice-item:has(input:checked) {
    border-color: var(--color-red);
    background: #fdf4f2;
    color: var(--color-navy);
  }

  .form-submit {
    margin-top: 32px; padding-top: 28px; border-top: 1px solid var(--color-border);
  }
  .form-submit-note {
    font-size: .82rem; color: var(--color-text-light);
    margin-top: 14px; text-align: center; line-height: 1.55;
  }

  /* Trust Sidebar */
  .trust-panel {
    position: sticky; top: 84px;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 28px 26px;
    box-shadow: var(--shadow-sm);
  }
  @media (max-width: 900px) { .trust-panel { position: static; } }
  .trust-panel h3 {
    font-size: .78rem; text-transform: uppercase; letter-spacing: .1em;
    font-family: var(--font-sans); color: var(--color-red); font-weight: 700;
    margin-bottom: 14px;
  }
  .trust-list { list-style: none; padding: 0; margin: 0 0 24px 0; }
  .trust-item { display: flex; gap: 12px; margin-bottom: 16px; align-items: flex-start; }
  .trust-item:last-child { margin-bottom: 0; }
  .trust-icon {
    flex-shrink: 0; width: 28px; height: 28px;
    background: var(--color-cream); border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
  }
  .trust-text { flex: 1; }
  .trust-text h4 { font-family: var(--font-sans); font-size: .92rem; margin-bottom: 2px; color: var(--color-navy); font-weight: 600; }
  .trust-text p { font-size: .82rem; margin: 0; line-height: 1.55; color: var(--color-text-light); }

  .trust-divider {
    border: none; height: 1px; background: var(--color-border);
    margin: 22px 0;
  }

  .trust-alt h3 { margin-bottom: 10px; }
  .trust-alt p { font-size: .85rem; color: var(--color-text-light); margin-bottom: 10px; }
  .trust-alt a.email-link {
    display: inline-flex; align-items: center; gap: 6px;
    color: var(--color-navy); font-weight: 600; font-size: .92rem;
    text-decoration: none; border-bottom: 1px solid var(--color-navy);
    padding-bottom: 1px;
  }
  .trust-alt a.email-link:hover { color: var(--color-red); border-color: var(--color-red); }

  @media (max-width: 680px) {
    .hero { padding: 48px 0 40px; }
    .form-wrap { padding: 40px 0 60px; }
  }
</style>
