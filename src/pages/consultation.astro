          <h3>Your Privacy</h3>
          <ul class="trust-list">
            <li class="trust-item">
              <div class="trust-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="#0f1f3d" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2l5 2v4c0 3-2.5 5.5-5 6-2.5-.5-5-3-5-6V4l5-2z"/></svg>
