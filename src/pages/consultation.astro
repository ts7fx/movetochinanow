    .trust-list { list-style: none; padding: 0; margin: 0 0 24px 0; }
    .trust-item { display: flex; gap: 12px; margin-bottom: 16px; align-items: flex-start; }
    .trust-item:last-child { margin-bottom: 0; }
    .trust-icon {
      flex-shrink: 0; width: 28px; height: 28px;
      background: var(--color-cream); border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
