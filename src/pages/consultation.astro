                <div class="form-field">
                  <label class="form-label">Preferred contact method <span class="form-req">*</span></label>
                  <div class="choice-grid" role="radiogroup" aria-label="Preferred contact method">
                    <label class="choice-item"><input type="radio" name="contact_method" value="email" required> Email</label>
                    <label class="choice-item"><input type="radio" name="contact_method" value="whatsapp"> WhatsApp</label>
                    <label class="choice-item"><input type="radio" name="contact_method" value="wechat"> WeChat</label>
                    <label class="choice-item"><input type="radio" name="contact_method" value="phone"> Phone</label>
                  </div>
                </div>
              </div>

              <div class="form-row form-row--single">
                <div class="form-field">
                  <label class="form-label" for="contact_handle">Phone / WhatsApp / WeChat ID</label>
                  <input class="form-input" type="text" id="contact_handle" name="contact_handle" placeholder="Include country code if phone / WhatsApp" autocomplete="tel">
                  <div class="form-helper">Only needed if you selected WhatsApp, WeChat, or Phone above.</div>
                </div>
              </div>
            </div>

            <!-- Submit -->
            <div class="form-submit">
              <button type="submit" class="btn btn-primary btn-lg btn-block">Send My Request</button>
              <p class="form-submit-note">
                By submitting, you consent to us contacting you about your consultation. We never share your details or use them for marketing.
              </p>
            </div>

          </form>
        </div>

