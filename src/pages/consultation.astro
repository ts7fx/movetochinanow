  <!-- Form Section -->
  <section class="form-wrap">
    <div class="container">
      <div class="form-layout">

        <!-- Form Card -->
        <div class="form-card">
          <div class="form-intro">
            <h2>Consultation Request</h2>
            <p>The more accurately you describe your situation, the more useful your first call will be. Fields marked <span style="color: var(--color-red); font-weight:600;">*</span> are required.</p>
          </div>

          <form action="https://formspree.io/f/maqababr" method="POST" novalidate>

            <input type="hidden" name="_subject" value="New consultation request — movetochinanow.com">
            <input type="hidden" name="_next" value="https://movetochinanow.com/consultation?sent=1">
            <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off">

            <!-- Section 1: About You -->
            <div class="form-section">
              <div class="form-section-title">
                <span class="form-section-num">01</span>
                <h3>About You</h3>
              </div>

              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="name">Full Name <span class="form-req">*</span></label>
                  <input class="form-input" type="text" id="name" name="name" required autocomplete="name">
                </div>
                <div class="form-field">
                  <label class="form-label" for="email">Email Address <span class="form-req">*</span></label>
                  <input class="form-input" type="email" id="email" name="email" required autocomplete="email">
                </div>
              </div>

              <div class="form-row">
                <div class="form-field">
                  <label class="form-label" for="nationality">Nationality <span class="form-req">*</span></label>
                  <input class="form-input" type="text" id="nationality" name="nationality" required placeholder="e.g. American, British, Australian">
                  <div class="form-helper">Affects which background check document you'll need (FBI, ACRO, etc.).</div>
                </div>
                <div class="form-field">
                  <label class="form-label" for="location">Where are you now? <span class="form-req">*</span></label>
                  <select class="form-select" id="location" name="location" required>
                    <option value="">Select an option</option>
                    <option value="in_china">Currently in China</option>
                    <option value="outside_china">Outside China</option>
                    <option value="moving_soon">Outside, moving within 12 months</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Section 2: Your Situation -->
            <div class="form-section">
              <div class="form-section-title">
                <span class="form-section-num">02</span>
                <h3>Your Situation</h3>
              </div>

              <div class="form-row form-row--single">
                <div class="form-field">
                  <label class="form-label">Which pathway are you exploring? <span class="form-req">*</span></label>
