      border-radius: 100px; color: #f5b7b1; font-size: .8rem; font-weight: 600;
      letter-spacing: .06em; text-transform: uppercase; padding: 5px 14px; margin-bottom: 22px;
    }
    .hero-badge-dot { width: 7px; height: 7px; background: var(--color-red-light); border-radius: 50%; }
    .hero h1 { color: var(--color-white); margin-bottom: 18px; }
    .hero-sub { font-size: 1.15rem; color: rgba(255,255,255,.75); max-width: 640px; margin-bottom: 32px; line-height: 1.65; }
    .hero-actions { display: flex; flex-wrap: wrap; gap: 14px; margin-bottom: 52px; }
    .hero-stats { display: flex; flex-wrap: wrap; gap: 32px; padding-top: 40px; border-top: 1px solid rgba(255,255,255,.12); }
    .hero-stat-num { font-family: var(--font-serif); font-size: 2rem; font-weight: 700; color: var(--color-white); display: block; line-height: 1; margin-bottom: 5px; }
    .hero-stat-label { font-size: .82rem; color: rgba(255,255,255,.6); text-transform: uppercase; letter-spacing: .06em; font-weight: 500; }

    /* TOC Bar */
    .toc-bar { background: var(--color-cream); border-bottom: 1px solid var(--color-border); padding: 18px 0; }
    .toc-inner { display: flex; flex-wrap: wrap; gap: 8px 20px; align-items: center; }
    .toc-label { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--color-text-light); white-space: nowrap; }
    .toc-link {
      font-size: .82rem; color: var(--color-navy-mid); text-decoration: none; font-weight: 500;
      padding: 3px 10px; border-radius: 100px; border: 1px solid var(--color-border);
      background: var(--color-white); transition: background .15s, border-color .15s;
    }
    .toc-link:hover { background: var(--color-navy); border-color: var(--color-navy); color: var(--color-white); }

    /* Sections */
    .section { padding: 80px 0; }
    .section--cream { background: var(--color-cream); }
    .section--navy { background: var(--color-navy); }
    .section--navy h2, .section--navy h3, .section--navy h4 { color: var(--color-white); }
    .section--navy p, .section--navy li { color: rgba(255,255,255,.75); }
    .section--navy strong { color: var(--color-white); }
    .section-label { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: var(--color-red); margin-bottom: 10px; display: block; }
    .section-label--light { color: #f5b7b1; }
    .section-title { margin-bottom: 16px; }
    .section-lead { font-size: 1.1rem; color: var(--color-text-light); max-width: 640px; margin-bottom: 48px; line-height: 1.65; }
    .section-lead--light { color: rgba(255,255,255,.65); }

    /* Pathway Cards */
    .pathway-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(248px, 1fr)); gap: 20px; margin-bottom: 32px; }
    .pathway-card {
      background: var(--color-white); border-radius: var(--radius-lg);
      border: 1px solid var(--color-border); padding: 28px 24px;
      box-shadow: var(--shadow-sm); transition: box-shadow .2s, transform .2s;
    }
    .pathway-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .pathway-icon {
      width: 44px; height: 44px; background: var(--color-cream);
      border-radius: var(--radius-md); display: flex; align-items: center;
      justify-content: center; margin-bottom: 16px;
    }
    .pathway-card h4 { margin-bottom: 10px; }
    .pathway-card ul { font-size: .88rem; }

    /* Benefits Grid */
    .benefits-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; }
    .benefit-item {
      display: flex; gap: 14px; align-items: flex-start;
      background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
      border-radius: var(--radius-md); padding: 20px 18px;
    }
    .benefit-icon {
      width: 36px; height: 36px; background: rgba(192,57,43,.25);
      border-radius: var(--radius-sm); display: flex; align-items: center;
      justify-content: center; flex-shrink: 0;
    }
    .benefit-text h4 { font-size: 1rem; margin-bottom: 4px; }
    .benefit-text p { font-size: .87rem; margin: 0; }

    /* Comparison Table */
    .compare-table {
      width: 100%; border-collapse: collapse; border-radius: var(--radius-md);
      overflow: hidden; box-shadow: var(--shadow-md); font-size: .92rem;
    }
    .compare-table thead { background: var(--color-navy); color: var(--color-white); }
    .compare-table th { padding: 16px 20px; text-align: left; font-family: var(--font-sans); font-weight: 600; font-size: .85rem; letter-spacing: .03em; }
    .compare-table td { padding: 14px 20px; border-bottom: 1px solid var(--color-border); color: var(--color-text-mid); vertical-align: top; }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table tbody tr:nth-child(even) { background: var(--color-cream); }
    .compare-table tbody tr:hover { background: #efeade; }
    .compare-table .good { color: #1a7a4a; font-weight: 600; }
    .compare-table .bad { color: var(--color-red); font-weight: 600; }
    .compare-table .neutral { color: var(--color-text-light); }
    .col-feature { font-weight: 600; color: var(--color-navy); }

    /* Steps */
    .steps-list { list-style: none; padding: 0; }
    .step-item { display: flex; gap: 24px; padding: 28px 0; border-bottom: 1px solid var(--color-border); align-items: flex-start; }
    .step-item:last-child { border-bottom: none; }
    .step-num {
      width: 44px; height: 44px; background: var(--color-navy); color: var(--color-white);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-family: var(--font-serif); font-size: 1.05rem; font-weight: 700; flex-shrink: 0;
    }
    .step-content h4 { margin-bottom: 6px; }
    .step-content p { font-size: .93rem; margin-bottom: 0; }
    .step-tip {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: .78rem; font-weight: 600; background: #fff7ed;
      border: 1px solid #fed7aa; color: #9a3412; border-radius: 100px;
      padding: 3px 12px; margin-top: 8px;
    }

    /* Document Cards */
    .doc-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; }
    .doc-card { background: var(--color-white); border: 1px solid var(--color-border); border-left: 4px solid var(--color-navy); border-radius: var(--radius-md); padding: 20px 20px; }
    .doc-card h4 { font-size: .98rem; margin-bottom: 8px; }
    .doc-card p { font-size: .87rem; margin: 0; }
    .doc-card.required { border-left-color: var(--color-red); }
    .doc-card.conditional { border-left-color: #d97706; }
    .doc-badge { font-size: .7rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; padding: 2px 8px; border-radius: 100px; margin-bottom: 8px; display: inline-block; }
    .doc-badge.req { background: #fee2e2; color: #991b1b; }
    .doc-badge.cond { background: #fef3c7; color: #92400e; }
    .doc-badge.opt { background: #e0f2fe; color: #075985; }

    /* Timeline */
    .timeline-visual { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 36px; box-shadow: var(--shadow-sm); margin-bottom: 32px; }
    .timeline-track { position: relative; padding-left: 32px; }
    .timeline-track::before { content: ''; position: absolute; left: 10px; top: 6px; bottom: 6px; width: 2px; background: linear-gradient(to bottom, var(--color-red), var(--color-navy)); border-radius: 2px; }
    .timeline-event { position: relative; padding: 0 0 28px 24px; }
    .timeline-event:last-child { padding-bottom: 0; }
    .timeline-dot { position: absolute; left: -24px; top: 5px; width: 14px; height: 14px; border-radius: 50%; background: var(--color-navy); border: 3px solid var(--color-white); box-shadow: 0 0 0 2px var(--color-navy); }
    .timeline-dot.active { background: var(--color-red); box-shadow: 0 0 0 2px var(--color-red); }
    .timeline-label { font-size: .72rem; text-transform: uppercase; letter-spacing: .08em; color: var(--color-text-light); font-weight: 700; margin-bottom: 4px; }
    .timeline-title { font-size: 1rem; font-weight: 600; color: var(--color-navy); margin-bottom: 4px; }
    .timeline-desc { font-size: .87rem; color: var(--color-text-light); margin: 0; }

    /* Cost Cards */
    .cost-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; }
    .cost-card { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 24px 20px; text-align: center; box-shadow: var(--shadow-sm); }
    .cost-card .amount { font-family: var(--font-serif); font-size: 1.8rem; font-weight: 700; color: var(--color-navy); display: block; margin-bottom: 6px; }
    .cost-card .label { font-size: .82rem; color: var(--color-text-light); text-transform: uppercase; letter-spacing: .06em; font-weight: 600; margin-bottom: 8px; display: block; }
    .cost-card p { font-size: .82rem; color: var(--color-text-light); margin: 0; }

    /* FAQ */
    .faq-list { list-style: none; padding: 0; }
    .faq-item { border-bottom: 1px solid var(--color-border); }
    .faq-item:first-child { border-top: 1px solid var(--color-border); }
    .faq-question {
      display: flex; justify-content: space-between; align-items: center; gap: 16px;
      padding: 20px 0; cursor: pointer; background: none; border: none; text-align: left;
      width: 100%; font-family: var(--font-sans); font-size: 1rem; font-weight: 600;
      color: var(--color-navy); line-height: 1.4;
    }
    .faq-question:hover { color: var(--color-red); }
    .faq-icon { flex-shrink: 0; transition: transform .2s; }
    .faq-answer { max-height: 0; overflow: hidden; transition: max-height .3s ease, padding .2s; }
    .faq-answer.open { max-height: 500px; }
    .faq-answer-inner { padding-bottom: 20px; font-size: .95rem; color: var(--color-text-mid); line-height: 1.7; }
    .faq-question[aria-expanded="true"] .faq-icon { transform: rotate(45deg); }

    /* CTA Band */
    .cta-band { background: var(--color-navy); padding: 64px 0; text-align: center; }
    .cta-band h2 { color: var(--color-white); margin-bottom: 14px; }
    .cta-band p { color: rgba(255,255,255,.7); font-size: 1.05rem; max-width: 560px; margin: 0 auto 32px; }
    .cta-band-actions { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; }

    /* CTA Box (inline) */
    .cta-box {
      background: var(--color-navy); border-radius: var(--radius-lg); padding: 40px;
      display: flex; flex-direction: column; align-items: flex-start; gap: 16px; margin: 48px 0;
    }
    .cta-box h3 { color: var(--color-white); margin: 0; }
    .cta-box p { color: rgba(255,255,255,.7); margin: 0; }
    @media (min-width: 640px) {
      .cta-box { flex-direction: row; align-items: center; }
      .cta-box-text { flex: 1; }
    }

    /* Alert & Info Boxes */
    .alert { display: flex; gap: 14px; align-items: flex-start; background: #fff7ed; border: 1px solid #fed7aa; border-radius: var(--radius-md); padding: 18px 20px; margin: 24px 0; }
    .alert-icon { flex-shrink: 0; margin-top: 2px; }
    .alert-text { font-size: .9rem; color: #7c2d12; line-height: 1.55; }
    .alert-text strong { color: #7c2d12; }
    .info-box { display: flex; gap: 14px; align-items: flex-start; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: var(--radius-md); padding: 18px 20px; margin: 24px 0; }
    .info-box-icon { flex-shrink: 0; margin-top: 2px; }
    .info-box-text { font-size: .9rem; color: #1e3a5f; line-height: 1.55; }

    /* Pullquote */
    .pullquote {
      border-left: 4px solid var(--color-red); background: var(--color-cream);
      border-radius: 0 var(--radius-md) var(--radius-md) 0; padding: 22px 28px; margin: 32px 0;
      font-family: var(--font-serif); font-size: 1.15rem; color: var(--color-navy);
      line-height: 1.55; font-style: italic;
    }

    /* Limits Grid */
    .limits-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 14px; }
    .limit-item { display: flex; gap: 12px; align-items: flex-start; padding: 16px; border-radius: var(--radius-md); border: 1px solid var(--color-border); background: var(--color-white); }
    .limit-icon { width: 32px; height: 32px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .limit-icon.warn { background: #fef9c3; }
    .limit-icon.stop { background: #fee2e2; }
    .limit-text h4 { font-size: .95rem; margin-bottom: 4px; }
    .limit-text p { font-size: .84rem; margin: 0; }

    /* Decision Cards */
    .decision-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    @media (max-width: 640px) { .decision-cols { grid-template-columns: 1fr; } }
    .decision-card { border-radius: var(--radius-lg); padding: 28px 24px; }
    .decision-card.yes { background: #f0fdf4; border: 1px solid #bbf7d0; }
    .decision-card.no { background: #fff7ed; border: 1px solid #fed7aa; }
    .decision-card h3 { margin-bottom: 14px; font-size: 1.2rem; }
    .decision-card.yes h3 { color: #166534; }
    .decision-card.no h3 { color: #9a3412; }
    .decision-card li { font-size: .9rem; }
    .decision-card.yes li { color: #166534; }
    .decision-card.no li { color: #9a3412; }

    /* Footer */
