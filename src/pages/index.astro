      --shadow-lg: 0 12px 40px rgba(0,0,0,.14), 0 4px 12px rgba(0,0,0,.08);
    }
    body {
      font-family: var(--font-sans);
      font-size: 17px;
      line-height: 1.7;
      color: var(--color-text);
      background: var(--color-white);
