---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Thank You — Seres Immigration"
  description="Your consultation request has been received. A consultant will reply within 24 hours."
  canonical="https://movetochinanow.com/thank-you"
  robots="noindex, follow"
>
  <section class="ty-wrap">
    <div class="container--narrow">
      <div class="ty-card">
        <div class="ty-check" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#166534" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </div>
        <span class="section-label" style="display:block; text-align:center;">Request Received</span>
        <h1 class="text-balance" style="text-align:center; margin-bottom: 18px;">Thank You — We'll Be in Touch Within 24 Hours</h1>
        <p style="text-align:center; font-size:1.05rem; color: var(--color-text-mid); max-width: 560px; margin: 0 auto 36px;">
          A consultant is personally reviewing your submission. You'll receive an initial assessment at the email address you provided — usually within a few hours, always within 24.
        </p>

        <div class="ty-steps">
          <div class="ty-step">
            <div class="ty-step-num">1</div>
            <div>
              <h3>Check your inbox</h3>
              <p>Our reply comes from a real Shenzhen/HK consultant, not a template. If you don't see it, check your spam folder and add <strong>info@seresimmigration.com</strong> to your safe senders.</p>
            </div>
          </div>
          <div class="ty-step">
            <div class="ty-step-num">2</div>
            <div>
              <h3>Review the initial assessment</h3>
              <p>We'll tell you which pathway fits your situation best, what documents you'll need, realistic timelines, and where the risks are for your specific case.</p>
            </div>
          </div>
          <div class="ty-step">
            <div class="ty-step-num">3</div>
            <div>
              <h3>Book a free 30-minute call</h3>
              <p>If you want to go deeper, reply to the email with your preferred times. We'll schedule a video call at no cost.</p>
            </div>
          </div>
        </div>

        <div class="ty-actions">
          <a href="/" class="btn btn-primary">Back to the Guide</a>
          <a href="mailto:info@seresimmigration.com" class="btn btn-navy">Email Us Directly</a>
        </div>
      </div>

      <p class="ty-support">
        Something urgent? Write to <a href="mailto:info@seresimmigration.com">info@seresimmigration.com</a> directly.
      </p>
    </div>
  </section>
</Layout>

<style is:global>
  .ty-wrap {
    background: var(--color-cream);
    padding: 72px 0 96px;
    min-height: calc(100vh - 64px - 36px);
  }
  .ty-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 56px 56px 48px;
    box-shadow: var(--shadow-md);
  }
  @media (max-width: 640px) {
    .ty-card { padding: 36px 24px; }
    .ty-wrap { padding: 48px 0 64px; }
  }
  .ty-check {
    width: 64px; height: 64px; background: #dcfce7;
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    margin: 0 auto 24px;
  }
  .ty-steps {
    display: flex; flex-direction: column; gap: 22px;
    max-width: 560px; margin: 0 auto 40px;
  }
  .ty-step {
    display: flex; gap: 18px; align-items: flex-start;
    padding: 22px 22px; border: 1px solid var(--color-border);
    border-radius: var(--radius-md); background: var(--color-cream);
  }
  .ty-step-num {
    flex-shrink: 0; width: 36px; height: 36px;
    background: var(--color-navy); color: var(--color-white);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-family: var(--font-serif); font-size: 1rem; font-weight: 700;
  }
  .ty-step h3 {
    font-family: var(--font-sans); font-size: 1rem; font-weight: 600;
    color: var(--color-navy); margin-bottom: 4px;
  }
  .ty-step p { font-size: .9rem; color: var(--color-text-mid); margin: 0; line-height: 1.6; }
  .ty-actions {
    display: flex; flex-wrap: wrap; gap: 12px; justify-content: center;
  }
  .ty-support {
    text-align: center; font-size: .88rem;
    color: var(--color-text-light); margin-top: 28px;
  }
</style>
