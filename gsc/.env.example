# Google Cloud OAuth client (create at https://console.cloud.google.com/apis/credentials)
# OAuth client type: "Desktop app" — redirect URI is set programmatically to http://localhost:3456/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Filled in automatically after running `npm run auth`
GSC_REFRESH_TOKEN=

# GSC site identifier. Use `sc-domain:movetochinanow.com` for Domain property,
# or `https://movetochinanow.com/` for URL prefix property.
GSC_SITE_URL=sc-domain:movetochinanow.com
